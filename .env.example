# OpenAI API Key (required for embeddings and chat)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Backend settings
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o
CHUNK_SIZE=500
CHUNK_OVERLAP=75
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
